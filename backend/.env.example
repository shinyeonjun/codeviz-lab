APP_NAME=CodeViz Backend
APP_VERSION=0.1.0
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
DATABASE_URL=postgresql+psycopg://codeviz:codeviz@127.0.0.1:55433/codeviz
RUNNER_BACKEND=docker
RUNNER_TIMEOUT_SECONDS=5
RUNNER_C_TIMEOUT_SECONDS=12
RUNNER_DOCKER_IMAGE=codeviz-python-sandbox:latest
RUNNER_DOCKER_C_IMAGE=codeviz-c-sandbox:latest
RUNNER_DOCKER_MEMORY_LIMIT=256m
RUNNER_DOCKER_CPUS=0.5
RUNNER_DOCKER_PIDS_LIMIT=64
RUNNER_DOCKER_TMPFS_SIZE=64m
RUNNER_MAX_TRACE_STEPS=0
RUNNER_MAX_STDOUT_CHARS=10000
RUNNER_MAX_SOURCE_CODE_CHARS=20000
RUNNER_MAX_STDIN_CHARS=4000
VISUALIZATION_SELECTOR_BACKEND=manual
OPENAI_API_KEY= 
OPENAI_MODEL=gpt-5-mini
OPENAI_API_URL=https://api.openai.com/v1/responses
OPENAI_TIMEOUT_SECONDS=8
OPENAI_MAX_OUTPUT_TOKENS=600
OPENAI_REASONING_EFFORT=low
OPENAI_TEXT_VERBOSITY=low
OPENAI_PROJECT_ID=
OPENAI_ORGANIZATION_ID=
